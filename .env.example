# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this file to  .env  and fill in your values.
# The .env file is your secret file. Never share it or upload it to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Anthropic API key (required) ──────────────────────────────────────────
#    Get yours at: https://console.anthropic.com  →  API Keys
#    It starts with  sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── 2. Gmail settings (required for email sending) ───────────────────────────
#
#    You need a Gmail App Password — NOT your normal Gmail password.
#    Steps to get one (takes 2 minutes):
#
#    a) Go to your Google Account:  https://myaccount.google.com
#    b) Click  Security
#    c) Under "How you sign in to Google", click  2-Step Verification
#       (If 2FA is not turned on, turn it on first — it's just a phone check)
#    d) Scroll to the bottom and click  App passwords
#    e) Under "App name" type:  Job Agent
#    f) Click  Create
#    g) Google shows a 16-character password like: abcd efgh ijkl mnop
#    h) Copy it (including spaces is fine) and paste it below
#
GMAIL_ADDRESS=alinafemaliro@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here


# ── 3. Email recipient ───────────────────────────────────────────────────────
#    Where to send the daily digest. Default: your own Gmail.
EMAIL_TO=alinafemaliro@gmail.com

# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy this to  .env  and fill in your real values.
# .env is secret (never uploaded). This file is just a template.
# ─────────────────────────────────────────────────────────────────────────────

# STEP 1 · Anthropic API key — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# STEP 2 · Gmail — create an App Password at myaccount.google.com/security
GMAIL_ADDRESS=alinafemaliro@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=alinafemaliro@gmail.com

# STEP 3 · Google Sheet — follow the instructions in .env.example.full for setup
GOOGLE_SHEET_ID=your-sheet-id-from-the-url
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...paste full json on one line..."}
